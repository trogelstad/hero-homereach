{
  "cleanUrls": true,
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/programs.html", "destination": "/programs", "permanent": true },
    { "source": "/who-we-serve.html", "destination": "/who-we-serve", "permanent": true },
    { "source": "/about.html", "destination": "/about", "permanent": true },
    { "source": "/contact.html", "destination": "/contact", "permanent": true },
    { "source": "/quiz", "destination": "/tools/quiz/", "permanent": true },
    { "source": "/quiz.html", "destination": "/tools/quiz/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*).pdf",
      "headers": [
        { "key": "Content-Type", "value": "application/pdf" }
      ]
    }
  ]
}
